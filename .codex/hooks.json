{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/format_edited_files.mjs\"",
            "timeout": 30,
            "statusMessage": "Formatting edited files"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/lint_on_stop.mjs\"",
            "timeout": 60,
            "statusMessage": "Running ESLint"
          }
        ]
      }
    ]
  }
}
